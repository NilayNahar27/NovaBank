# NovaBank Net Banking — copy into real env files (do not commit secrets).
#
# Backend: copy server/.env.example → server/.env and edit.
# Frontend (optional): copy client/.env.example → client/.env for API URL overrides.

# --- server/.env ---
# PORT=5000
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_NAME=novabank_atm
# JWT_SECRET=use_a_long_random_string
# JWT_EXPIRES_IN=7d
# CORS_ORIGIN=http://localhost:5173

# --- client/.env (optional) ---
# VITE_API_URL=http://localhost:5000
# VITE_PROXY_TARGET=http://localhost:5000
